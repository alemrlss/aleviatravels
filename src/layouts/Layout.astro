---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Alevia Travels — Viajes a Latinoamérica desde España',
  description = 'Agencia de viajes especializada en Latinoamérica para latinoamericanos residentes en España. Vuelos, paquetes y experiencias a Colombia, México, Perú, Argentina y más.',
  image = '/og-image.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const schemaOrg = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "TravelAgency",
      "@id": "https://aleviatravels.es/#organization",
      "name": "Alevia Travels",
      "url": "https://aleviatravels.es",
      "telephone": "+34600000000",
      "email": "aleviatravelsteam@gmail.com",
      "description": "Agencia de viajes especializada en Latinoamérica para latinoamericanos residentes en España.",
      "areaServed": "España",
      "knowsLanguage": ["es"],
    },
    {
      "@type": "WebSite",
      "@id": "https://aleviatravels.es/#website",
      "url": "https://aleviatravels.es",
      "name": "Alevia Travels",
      "publisher": { "@id": "https://aleviatravels.es/#organization" }
    }
  ]
};
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Alevia Travels" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />

    <!-- Poppins: todos los pesos necesarios -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

    <style>
      *, *::before, *::after { box-sizing: border-box; }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: 'Poppins', system-ui, sans-serif;
        font-weight: 400;
        color: #383838;
        background-color: #FFFFFF;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* Custom scrollbar */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: #f1f1f1; }
      ::-webkit-scrollbar-thumb { background: #FF6E18; border-radius: 3px; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
