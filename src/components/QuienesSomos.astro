---
const valores = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/>`,
    titulo: 'Conocemos la región',
    descripcion: 'Expertos en destinos latinoamericanos, rutas y temporadas.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>`,
    titulo: 'Trato cercano',
    descripcion: 'Cada viajero es único. Te atendemos de forma personalizada.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>`,
    titulo: 'Transparencia total',
    descripcion: 'Precios claros, sin comisiones ocultas ni sorpresas.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>`,
    titulo: 'Siempre disponibles',
    descripcion: 'Respuesta garantizada en menos de 24 horas por WhatsApp.',
  },
];

const stats = [
  { valor: '500+', label: 'Viajeros satisfechos' },
  { valor: '20+', label: 'Destinos activos' },
  { valor: '5★', label: 'Valoración media' },
];
---

<section id="quienes-somos" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left -->
      <div data-animate="slide-left">
        <div class="inline-flex items-center gap-2 bg-brand-100 rounded-full px-4 py-1.5 mb-6">
          <svg class="w-4 h-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/>
          </svg>
          <span class="text-brand-600 text-sm font-semibold">Quiénes somos</span>
        </div>

        <h2 class="font-heading font-extrabold text-display-lg text-charcoal-700 mb-5">
          Una agencia que<br/>
          <span class="text-brand-500">te entiende</span>
        </h2>

        <p class="text-charcoal-400 text-lg font-light leading-relaxed mb-8">
          Alevia Travels nació en Madrid para conectar a los latinoamericanos que viven en España con los destinos que más les importan — ya sea volver a casa o descubrir nuevos lugares en la región.
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4 mb-8">
          {stats.map((s) => (
            <div class="bg-white border border-gray-100 rounded-2xl p-4 text-center shadow-sm hover:shadow-md hover:border-brand-200 transition-all duration-200">
              <div class="font-extrabold text-xl text-brand-500 leading-none mb-1">{s.valor}</div>
              <div class="text-charcoal-400 text-xs font-medium leading-tight">{s.label}</div>
            </div>
          ))}
        </div>

        <a
          href="tel:+34600000000"
          class="inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-600 text-white font-semibold text-sm px-6 py-3 rounded-xl shadow-brand transition-all duration-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
          Llámanos sin compromiso
        </a>
      </div>

      <!-- Right: imagen + 2x2 value cards -->
      <div data-animate="slide-right" data-delay="150" class="flex flex-col gap-4">

        <!-- Imagen del equipo / oficina -->
        <!--
          Sube tu foto a: public/images/equipo.jpg
          Sugerencia: foto del equipo, oficina en Madrid, o imagen corporativa.
          Tamaño recomendado: 800×450px
        -->
        <div class="relative rounded-2xl overflow-hidden h-52 bg-charcoal-600 border border-gray-100">
          <img
            src="/images/equipo.png"
            alt="El equipo de Alevia Travels en Madrid"
            class="w-full h-full object-cover"
            width="800"
            height="450"
            loading="lazy"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <!-- Placeholder si no hay imagen -->
          <div class="absolute inset-0 items-center justify-center flex-col gap-2 border-2 border-dashed border-white/15" style="display:none">
            <svg class="w-10 h-10 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
            </svg>
            <p class="text-white/30 text-xs font-medium">Foto del equipo</p>
            <code class="text-brand-400/50 text-xs">public/images/equipo.jpg</code>
          </div>
        </div>

        <!-- 2x2 value cards -->
        <div class="grid grid-cols-2 gap-4">
        {valores.map((v, i) => (
          <div class={`p-5 rounded-2xl border transition-all duration-200 ${i === 0 ? 'bg-brand-500 border-brand-500' : 'bg-warm-50 border-gray-100 hover:border-brand-200'}`}>
            <div class={`w-10 h-10 rounded-xl flex items-center justify-center mb-3 ${i === 0 ? 'bg-white/20' : 'bg-brand-500'}`}>
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={v.icon}></svg>
            </div>
            <h3 class={`font-heading font-bold text-sm mb-1.5 ${i === 0 ? 'text-white' : 'text-charcoal-700'}`}>{v.titulo}</h3>
            <p class={`text-xs font-light leading-relaxed ${i === 0 ? 'text-white/80' : 'text-charcoal-400'}`}>{v.descripcion}</p>
          </div>
        ))}
        </div><!-- fin grid 2x2 -->
      </div><!-- fin Right -->
    </div>
  </div>
</section>
