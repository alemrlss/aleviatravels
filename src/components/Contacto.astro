---
const whatsappUrl = 'https://wa.me/34600000000?text=Hola%2C%20me%20gustar%C3%ADa%20informaci%C3%B3n%20sobre%20un%20viaje%20a%20Latinoam%C3%A9rica';
const phoneUrl = 'tel:+34600000000';

const pasos = [
  {
    num: '01',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"/>`,
    titulo: 'Nos contactas',
    desc: 'Por WhatsApp o teléfono. Cuéntanos tu destino, fechas y número de viajeros.',
  },
  {
    num: '02',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`,
    titulo: 'Preparamos tu propuesta',
    desc: 'En menos de 24 horas recibes opciones con precios, vuelos y detalles.',
  },
  {
    num: '03',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>`,
    titulo: '¡A viajar!',
    desc: 'Confirmas, abonamos y nos encargamos de todo. Solo tienes que hacer las maletas.',
  },
];
---

<section id="contacto" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div data-animate class="text-center max-w-xl mx-auto mb-16">
      <div class="inline-flex items-center gap-2 bg-brand-100 rounded-full px-4 py-1.5 mb-5">
        <svg class="w-4 h-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span class="text-brand-600 text-sm font-semibold">Así de sencillo</span>
      </div>
      <h2 class="font-heading font-extrabold text-display-lg text-charcoal-700 mb-4">
        Planificar tu viaje<br/>nunca fue tan fácil
      </h2>
    </div>

    <!-- Pasos -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">
      {pasos.map((p, i) => (
        <div data-animate data-delay={i * 150} class="relative flex flex-col items-center text-center p-7 bg-warm-50 rounded-2xl border border-gray-100">
          <span class="absolute top-5 right-5 font-black text-4xl text-gray-100 font-heading leading-none select-none">{p.num}</span>
          <div class="w-14 h-14 bg-brand-500 rounded-2xl flex items-center justify-center mb-5 shadow-brand">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={p.icon}></svg>
          </div>
          <h3 class="font-heading font-bold text-charcoal-700 text-lg mb-2">{p.titulo}</h3>
          <p class="text-charcoal-400 text-sm font-light leading-relaxed">{p.desc}</p>
          {i < 2 && (
            <div class="hidden md:flex absolute -right-4 top-1/2 -translate-y-1/2 z-10 w-8 h-8 bg-white border border-gray-200 rounded-full items-center justify-center shadow-sm">
              <svg class="w-4 h-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- CTA principal -->
    <div data-animate data-delay="100" class="bg-charcoal-700 rounded-3xl overflow-hidden">
      <div class="relative p-10 sm:p-14">
        <div class="absolute top-0 right-0 w-80 h-80 bg-brand-500/15 rounded-full blur-[80px] -translate-y-1/3 translate-x-1/3 pointer-events-none"></div>

        <div class="relative z-10 flex flex-col lg:flex-row items-start lg:items-center justify-between gap-10">
          <div class="max-w-xl">
            <p class="text-brand-400 text-sm font-semibold tracking-wide mb-3 uppercase">Consulta gratuita · Sin compromiso</p>
            <h2 class="font-heading font-extrabold text-3xl sm:text-4xl text-white leading-tight mb-4">
              ¿Listo para tu<br/>próxima aventura?
            </h2>
            <p class="text-white/55 text-base font-light leading-relaxed">
              Contacta con nosotros hoy. Te respondemos en menos de 24 horas con opciones, precios y disponibilidad para tu destino.
            </p>
          </div>

          <!-- Botones -->
          <div class="flex flex-col gap-4 w-full lg:w-auto lg:min-w-56">
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-3 bg-brand-500 hover:bg-brand-600 text-white font-semibold px-8 py-4 rounded-xl shadow-brand-lg transition-all duration-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-400 focus:ring-offset-2 focus:ring-offset-charcoal-700"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Consultar por WhatsApp
            </a>

            <a
              href={phoneUrl}
              class="inline-flex items-center justify-center gap-3 bg-white/10 hover:bg-white/18 border border-white/15 text-white font-semibold px-8 py-4 rounded-xl transition-all duration-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-white/40 focus:ring-offset-2 focus:ring-offset-charcoal-700"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
              </svg>
              Llamar: +34 600 000 000
            </a>

            <p class="text-center text-white/30 text-xs font-light">
              Horario: Lunes–Viernes, 9h–19h
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
