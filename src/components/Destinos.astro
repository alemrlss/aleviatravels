---
// Imágenes: coloca tus fotos en public/images/destinos/
// Nombre de archivo sugerido para cada destino (ej: colombia.jpg, mexico.jpg...)
const destinos = [
  {
    nombre: 'Colombia',
    slug: 'colombia',
    desc: 'Café, cultura y el mar Caribe. Cartagena, Medellín y la Amazonía en un solo viaje.',
    tags: ['Cartagena', 'Medellín', 'Bogotá'],
    flag: '🇨🇴',
    accent: '#F4C542',
  },
  {
    nombre: 'México',
    slug: 'mexico',
    desc: 'Historia milenaria, gastronomía icónica y las mejores playas del Caribe.',
    tags: ['Cancún', 'CDMX', 'Oaxaca'],
    flag: '🇲🇽',
    accent: '#4CAF50',
  },
  {
    nombre: 'Perú',
    slug: 'peru',
    desc: 'Machu Picchu, Lima gastronómica y la magia de los Andes que no olvidarás.',
    tags: ['Cusco', 'Lima', 'Machu Picchu'],
    flag: '🇵🇪',
    accent: '#E53935',
  },
  {
    nombre: 'Argentina',
    slug: 'argentina',
    desc: 'Buenos Aires, la Patagonia infinita y las Cataratas del Iguazú.',
    tags: ['Buenos Aires', 'Patagonia', 'Iguazú'],
    flag: '🇦🇷',
    accent: '#1E88E5',
  },
  {
    nombre: 'Rep. Dominicana',
    slug: 'dominicana',
    desc: 'Punta Cana y el Caribe más vibrante. Sol, playa y ambiente latino a tope.',
    tags: ['Punta Cana', 'Santo Domingo', 'Samaná'],
    flag: '🇩🇴',
    accent: '#00ACC1',
  },
  {
    nombre: 'Cuba',
    slug: 'cuba',
    desc: 'La Habana atemporal, Trinidad colonial y Varadero, las playas más famosas.',
    tags: ['La Habana', 'Varadero', 'Trinidad'],
    flag: '🇨🇺',
    accent: '#FF6E18',
  },
];
---

<section id="destinos" class="py-24 bg-warm-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="max-w-2xl mb-16">
      <div class="inline-flex items-center gap-2 bg-brand-100 rounded-full px-4 py-1.5 mb-5">
        <svg class="w-4 h-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>
        </svg>
        <span class="text-brand-600 text-sm font-semibold">Destinos destacados</span>
      </div>
      <h2 class="font-heading font-extrabold text-display-lg text-charcoal-700 mb-4">
        Latinoamérica,<br/>tu continente
      </h2>
      <p class="text-charcoal-400 text-lg font-light leading-relaxed">
        Armamos el viaje perfecto a los destinos que más quieres conocer o reencontrar.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {destinos.map((d) => (
        <article class="group bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 cursor-pointer">

          <!-- Imagen del destino -->
          <!--
            Sube tu foto a: public/destinos/{slug}.png
            Tamaño recomendado: 600×360px, formato .png
          -->
          <div class="relative h-44 overflow-hidden bg-charcoal-600">
            <img
              src={`/destinos/${d.slug}.png`}
              alt={`Viaje a ${d.nombre} desde España`}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              width="600"
              height="360"
              loading="lazy"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <!-- Placeholder si no hay imagen -->
            <div
              class="absolute inset-0 items-center justify-between px-6 border-b-2 border-brand-500/30"
              style={`display:none; background: linear-gradient(135deg, ${d.accent}20 0%, ${d.accent}35 100%)`}
            >
              <span class="text-7xl leading-none select-none">{d.flag}</span>
              <div class="text-right">
                <p class="text-white/20 text-xs font-light">Sin imagen</p>
                <p class="text-white/15 text-xs font-light">public/images/destinos/{d.slug}.jpg</p>
              </div>
            </div>
            <!-- Overlay gradiente siempre presente -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent pointer-events-none"></div>
            <!-- Flag badge sobre la imagen -->
            <div class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm rounded-lg px-2 py-1 flex items-center gap-1.5">
              <span class="text-lg leading-none">{d.flag}</span>
              <span class="text-charcoal-700 text-xs font-bold">{d.nombre}</span>
            </div>
          </div>

          <!-- Contenido -->
          <div class="p-5">
            <p class="text-charcoal-400 text-sm leading-relaxed mb-4 font-light">{d.desc}</p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 mb-4">
              {d.tags.map((tag) => (
                <span class="inline-flex items-center gap-1 text-xs font-medium text-charcoal-500 bg-gray-100 px-2.5 py-1 rounded-full">
                  <svg class="w-2.5 h-2.5 text-brand-500" fill="currentColor" viewBox="0 0 24 24">
                    <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-2.076 3.81-5.16 3.81-9.294a8.1 8.1 0 10-16.2 0c0 4.134 1.865 7.218 3.81 9.294a19.517 19.517 0 002.681 2.28 16.76 16.76 0 001.147.745z" clip-rule="evenodd"/>
                  </svg>
                  {tag}
                </span>
              ))}
            </div>

            <!-- CTA -->
            <a
              href="/#contacto"
              class="inline-flex items-center gap-1.5 text-brand-500 hover:text-brand-600 text-sm font-semibold transition-colors duration-200 focus:outline-none focus:underline"
            >
              Ver paquetes
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-14 flex flex-col sm:flex-row items-center justify-between gap-4 bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
      <div>
        <p class="font-heading font-semibold text-charcoal-700 text-base">¿No ves tu destino?</p>
        <p class="text-charcoal-400 text-sm font-light mt-0.5">Viajamos a toda Latinoamérica y el resto del mundo.</p>
      </div>
      <div class="flex gap-3 flex-shrink-0">
        <a
          href="https://wa.me/34600000000?text=Hola%2C%20me%20gustar%C3%ADa%20informaci%C3%B3n%20sobre%20un%20viaje%20a%20Latinoam%C3%A9rica"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-600 text-white font-semibold text-sm px-6 py-3 rounded-xl shadow-brand transition-all duration-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Consultar por WhatsApp
        </a>
        <a
          href="tel:+34600000000"
          class="inline-flex items-center gap-2 bg-white border border-gray-200 hover:border-brand-300 text-charcoal-600 hover:text-brand-500 font-semibold text-sm px-5 py-3 rounded-xl transition-all duration-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
          Llamar
        </a>
      </div>
    </div>
  </div>
</section>
