---
const email = "aleviatravelsteam@gmail.com";
const whatsappUrl =
  "https://wa.me/34600000000?text=Hola%2C%20me%20gustar%C3%ADa%20informaci%C3%B3n%20sobre%20un%20viaje%20a%20Latinoam%C3%A9rica";
const currentYear = new Date().getFullYear();

const destinos = [
  "Colombia",
  "México",
  "Perú",
  "Argentina",
  "Rep. Dominicana",
  "Cuba",
];
const navLinks = [
  { label: "Inicio", href: "#inicio" },
  { label: "Quiénes Somos", href: "#quienes-somos" },
  { label: "Destinos", href: "#destinos" },
  { label: "Por qué elegirnos", href: "#por-que-elegirnos" },
  { label: "Testimonios", href: "#testimonios" },
  { label: "Blog", href: "/blog" },
];
---

<footer class="bg-charcoal-700 text-white/60">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Main footer -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 py-14 border-b border-white/10"
    >
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <!-- Logo placeholder -->
        <div class="mb-5">
          <div class="inline-flex h-12 w-40 items-center justify-center">
            <img
              src="/logo-footer.png"
              alt="Alevia Travels logo"
              class="h-full w-auto object-contain"
            />
          </div>
        </div>
        <p class="text-sm font-light leading-relaxed mb-6 max-w-xs">
          La agencia de viajes de referencia para latinoamericanos en España.
          Volvé a casa o explorá nuevos destinos con total confianza.
        </p>
        <!-- Contact quick -->
        <div class="space-y-2.5">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2.5 text-sm hover:text-brand-400 transition-colors duration-200 cursor-pointer group"
          >
            <svg
              class="w-4 h-4 text-brand-500 flex-shrink-0"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            +34 600 000 000
          </a>
          <a
            href={`mailto:${email}`}
            class="flex items-center gap-2.5 text-sm hover:text-brand-400 transition-colors duration-200 cursor-pointer"
          >
            <svg
              class="w-4 h-4 text-brand-500 flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
              ></path>
            </svg>
            {email}
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3
          class="font-heading font-semibold text-white text-sm tracking-wide mb-5"
        >
          Navegación
        </h3>
        <ul class="space-y-2.5">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm font-light hover:text-brand-400 transition-colors duration-200 cursor-pointer"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Destinos -->
      <div>
        <h3
          class="font-heading font-semibold text-white text-sm tracking-wide mb-5"
        >
          Destinos populares
        </h3>
        <ul class="space-y-2.5">
          {
            destinos.map((d) => (
              <li>
                <a
                  href="#destinos"
                  class="flex items-center gap-2 text-sm font-light hover:text-brand-400 transition-colors duration-200 cursor-pointer"
                >
                  <svg
                    class="w-3 h-3 text-brand-500 flex-shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
                    />
                  </svg>
                  {d}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- CTA column -->
      <div>
        <h3
          class="font-heading font-semibold text-white text-sm tracking-wide mb-5"
        >
          ¿Empezamos?
        </h3>
        <p class="text-sm font-light leading-relaxed mb-5">
          Consulta gratuita y sin compromiso. Te ayudamos a planificar el viaje
          de tu vida.
        </p>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold px-5 py-3 rounded-xl shadow-brand transition-all duration-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-400 focus:ring-offset-2 focus:ring-offset-charcoal-700"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
          Escribir ahora
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-4 py-6 text-xs font-light"
    >
      <p class="text-white/30">
        &copy; {currentYear} Alevia Travels. Todos los derechos reservados.
      </p>
      <p class="text-white/20">Madrid, España · aleviatravels.es</p>
    </div>
  </div>
</footer>
