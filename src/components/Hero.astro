---
const whatsappUrl = 'https://wa.me/34600000000?text=Hola%2C%20me%20gustar%C3%ADa%20informaci%C3%B3n%20sobre%20un%20viaje%20a%20Latinoam%C3%A9rica';
const phoneUrl = 'tel:+34600000000';
---

<section id="inicio" class="relative bg-white overflow-hidden" style="min-height: 100dvh; min-height: 100vh;">

  <!-- ── Decoración naranja top-right ── -->
  <div class="pointer-events-none select-none" aria-hidden="true">
    <!-- Círculo grande, solo trazo -->
    <div class="absolute -top-32 -right-32 w-[520px] h-[520px] rounded-full border-[40px] border-brand-500/8"></div>
    <!-- Círculo mediano sólido muy suave -->
    <div class="absolute top-16 right-8 w-20 h-20 rounded-full bg-brand-500/6"></div>
    <!-- Dot pattern cálido -->
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: radial-gradient(circle, #FF6E18 1.5px, transparent 1.5px); background-size: 36px 36px;"
    ></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full">
    <div class="grid lg:grid-cols-2 gap-0 items-stretch" style="min-height: inherit;">

      <!-- ── Columna izquierda: copy ── -->
      <div class="flex flex-col justify-center py-24 lg:py-0 lg:pr-12 xl:pr-20 order-2 lg:order-1">

        <!-- Badge animado -->
        <div class="inline-flex items-center gap-2.5 self-start bg-brand-50 border border-brand-200 rounded-full px-4 py-2 mb-10">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-400 opacity-60"></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-brand-500"></span>
          </span>
          <span class="text-brand-600 text-sm font-semibold tracking-wide">Agencia de viajes · Madrid</span>
        </div>

        <!-- Headline principal -->
        <h1 class="font-heading font-extrabold text-charcoal-700 mb-6 tracking-tight" style="font-size: clamp(2.4rem, 5.5vw, 4.5rem); line-height: 1.06;">
          Viaja a
          <span class="relative inline-block text-brand-500">
            Latinoamérica
            <!-- Subrayado SVG naranja -->
            <svg
              class="absolute -bottom-1 left-0 w-full overflow-visible"
              viewBox="0 0 400 10"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path d="M4 7 Q100 2 200 5 Q300 8 396 4" stroke="#FF6E18" stroke-width="3.5" stroke-linecap="round"/>
            </svg>
          </span>
          <br/>sin complicaciones.
        </h1>

        <!-- Subtítulo -->
        <p class="text-lg text-charcoal-400 font-light leading-relaxed max-w-lg mb-10">
          Vuelos, paquetes y experiencias diseñadas para ti. Atención personalizada en español y precios transparentes desde Madrid.
        </p>

        <!-- Trust pills -->
        <div class="flex flex-wrap gap-2.5 mb-10">
          {[
            { label: 'Consulta gratuita', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>` },
            { label: '500+ viajeros satisfechos', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>` },
            { label: 'Respuesta en 24h', icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>` },
          ].map((t) => (
            <span class="inline-flex items-center gap-2 bg-gray-50 border border-gray-200 text-charcoal-500 text-sm font-medium px-3.5 py-2 rounded-full">
              <svg class="w-4 h-4 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={t.icon}></svg>
              {t.label}
            </span>
          ))}
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold text-[15px] px-7 py-4 rounded-2xl shadow-brand-lg hover:shadow-brand transition-all duration-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-400 focus:ring-offset-2"
          >
            <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Consultar por WhatsApp
          </a>

          <a
            href={phoneUrl}
            class="inline-flex items-center justify-center gap-2.5 bg-white hover:bg-gray-50 border-2 border-gray-200 hover:border-brand-300 text-charcoal-600 hover:text-brand-600 font-semibold text-[15px] px-7 py-4 rounded-2xl transition-all duration-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2"
          >
            <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            Llamar ahora
          </a>
        </div>

        <!-- Línea de confianza -->
        <p class="mt-6 text-xs text-charcoal-400 font-light">
          Sin compromiso · Atención Lunes–Viernes 9h–19h
        </p>
      </div>

      <!-- ── Columna derecha: imagen ── -->
      <div class="relative order-1 lg:order-2 flex items-center justify-center lg:justify-end py-10 lg:py-10">

        <!-- Contenedor de imagen -->
        <div class="relative w-full max-w-[420px] lg:max-w-none lg:w-[88%]">

          <!-- Marco imagen principal -->
          <div class="relative rounded-3xl overflow-hidden shadow-2xl" style="aspect-ratio: 3/4;">
            <!--
              IMAGEN HERO — Sube tu foto a: public/images/hero.jpg
              Idea: aeropuerto, avión, familia reunida, destino latinoamericano.
              Tamaño óptimo: 840×1120px · Formato: .webp o .jpg
            -->
              <img
                id="hero-img"
                src="/images/hero.png"
                alt="Viajes a Latinoamérica desde España — Alevia Travels"
                class="w-full h-full object-cover"
                width="840"
                height="1120"
                fetchpriority="high"
                onerror="this.style.display='none'; document.getElementById('hero-placeholder').style.display='flex';"
              />

            <!-- Placeholder mientras no hay imagen (oculto por defecto) -->
            <div
              id="hero-placeholder"
              class="absolute inset-0 flex-col items-center justify-center gap-3 bg-gradient-to-br from-gray-100 to-gray-50 border-2 border-dashed border-gray-200"
              style="display:none"
            >
              <div class="w-16 h-16 rounded-2xl bg-brand-100 flex items-center justify-center">
                <svg class="w-8 h-8 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
                </svg>
              </div>
              <div class="text-center px-6">
                <p class="text-charcoal-500 text-sm font-semibold mb-1">Imagen principal del Hero</p>
                <code class="text-brand-500 text-xs">public/images/hero.jpg</code>
                <p class="text-gray-400 text-xs mt-1">Recomendado: 840 × 1120 px</p>
              </div>
            </div>

            <!-- Degradado inferior sobre imagen -->
            <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-black/35 to-transparent pointer-events-none"></div>

            <!-- Badge flotante inferior sobre imagen -->
            <div class="absolute bottom-5 left-4 right-4">
              <div class="bg-white/90 backdrop-blur-md rounded-2xl px-4 py-3.5 flex items-center gap-3 shadow-lg">
                <div class="w-10 h-10 bg-brand-500 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-charcoal-700 text-sm font-bold leading-tight">Más de 500 viajeros</p>
                  <p class="text-charcoal-400 text-xs font-light">nos valoran con 5 estrellas</p>
                </div>
                <!-- Stars -->
                <div class="ml-auto flex gap-0.5">
                  {[1,2,3,4,5].map(() => (
                    <svg class="w-3.5 h-3.5 text-brand-500" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- Tarjeta flotante superior-izquierda -->
          <div class="absolute -left-5 top-10 hidden sm:block">
            <div class="bg-white rounded-2xl px-4 py-3 shadow-xl border border-gray-100 flex items-center gap-3">
              <div class="w-9 h-9 bg-brand-50 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>
                </svg>
              </div>
              <div>
                <p class="font-bold text-charcoal-700 text-sm leading-tight">20+ destinos</p>
                <p class="text-charcoal-400 text-xs font-light">en Latinoamérica</p>
              </div>
            </div>
          </div>

          <!-- Tarjeta flotante derecha-centro -->
          <div class="absolute -right-5 top-1/2 -translate-y-1/2 hidden xl:block">
            <div class="bg-brand-500 rounded-2xl px-4 py-3 shadow-xl flex items-center gap-2.5">
              <svg class="w-5 h-5 text-white flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <div>
                <p class="font-bold text-white text-sm leading-tight">Resp. en 24h</p>
                <p class="text-white/70 text-xs font-light">garantizado</p>
              </div>
            </div>
          </div>

          <!-- Acento naranja esquina inferior derecha del frame -->
          <div class="absolute -bottom-3 -right-3 w-14 h-14 bg-brand-500 rounded-2xl -z-10"></div>
          <div class="absolute -top-3 -left-3 w-10 h-10 border-2 border-brand-500/30 rounded-xl -z-10"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Stats bar inferior ── -->
  <div class="relative z-10 border-t border-gray-100 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-gray-100">
        {[
          { valor: '500+', label: 'Viajeros felices' },
          { valor: '20+', label: 'Destinos activos' },
          { valor: '5★', label: 'Valoración media' },
          { valor: '24h', label: 'Tiempo de respuesta' },
        ].map((s) => (
          <div class="bg-white py-5 px-6 text-center">
            <div class="font-heading font-extrabold text-2xl text-brand-500 leading-none mb-1">{s.valor}</div>
            <div class="text-charcoal-400 text-xs font-medium">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  // Mostrar placeholder si la imagen falla
  const img = document.getElementById('hero-img') as HTMLImageElement;
  const placeholder = document.getElementById('hero-placeholder');
  if (img && placeholder) {
    if (img.complete && img.naturalWidth === 0) {
      img.style.display = 'none';
      placeholder.style.display = 'flex';
    }
  }
</script>
