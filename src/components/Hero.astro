---
const whatsappUrl = 'https://wa.me/34600000000?text=Hola%2C%20me%20gustar%C3%ADa%20informaci%C3%B3n%20sobre%20un%20viaje%20a%20Latinoam%C3%A9rica';
const phoneUrl = 'tel:+34600000000';
---

<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden bg-charcoal-700 pt-20">

  <!-- Fondo oscuro + glow naranja -->
  <div class="absolute inset-0 bg-gradient-to-r from-charcoal-700 via-charcoal-700 to-charcoal-600"></div>
  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-brand-500/10 to-transparent pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-brand-600/10 rounded-full blur-[120px] pointer-events-none"></div>

  <!-- Dot grid sutil -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #ffffff 1px, transparent 1px); background-size: 28px 28px;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center min-h-[75vh]">

      <!-- Izquierda: copy -->
      <div class="order-2 lg:order-1">

        <!-- Badge -->
        <div class="inline-flex items-center gap-2.5 bg-brand-500/15 border border-brand-500/25 rounded-full px-4 py-2 mb-8">
          <svg class="w-3.5 h-3.5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
          </svg>
          <span class="text-brand-300 text-sm font-semibold tracking-wide">Agencia de viajes en Madrid</span>
        </div>

        <!-- Headline -->
        <h1 class="font-heading font-extrabold text-display-xl text-white leading-[1.04] mb-6">
          Tu viaje<br/>
          <span class="text-brand-500">empieza aquí.</span>
        </h1>

        <!-- Sub -->
        <p class="text-lg sm:text-xl text-white/65 font-light leading-relaxed max-w-lg mb-8">
          Especialistas en Latinoamérica para viajeros que salen desde España. Vuelos, paquetes y experiencias a tu medida.
        </p>

        <!-- Trust pills -->
        <div class="flex flex-wrap gap-x-5 gap-y-2.5 mb-10">
          {[
            'Atención en español',
            'Paquetes personalizados',
            'Respuesta en 24h',
          ].map((t) => (
            <span class="flex items-center gap-1.5 text-white/55 text-sm font-medium">
              <svg class="w-3.5 h-3.5 text-brand-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              {t}
            </span>
          ))}
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2.5 bg-brand-500 hover:bg-brand-600 text-white font-semibold text-base px-7 py-4 rounded-xl shadow-brand-lg transition-all duration-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-400 focus:ring-offset-2 focus:ring-offset-charcoal-700"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Consultar por WhatsApp
          </a>
          <a
            href={phoneUrl}
            class="inline-flex items-center justify-center gap-2.5 bg-white/10 hover:bg-white/18 border border-white/15 text-white font-semibold text-base px-7 py-4 rounded-xl transition-all duration-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-white/40 focus:ring-offset-2 focus:ring-offset-charcoal-700"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            Llamar ahora
          </a>
        </div>
      </div>

      <!-- Derecha: imagen principal -->
      <div class="order-1 lg:order-2 flex items-center justify-center">
        <div class="relative w-full max-w-lg">

          <!-- Marco de la imagen -->
          <div class="relative rounded-3xl overflow-hidden aspect-[4/3] lg:aspect-[3/4] shadow-2xl">
            <!--
              IMAGEN HERO — Reemplaza el src con tu imagen.
              Sugerencia: foto de avión, aeropuerto, familia reunida, destino latinoamericano.
              Tamaño recomendado: 800×1000px o 1200×900px. Formatos: .webp, .jpg
            -->
            <img
              src="/images/hero.jpg"
              alt="Viajes a Latinoamérica desde España con Alevia Travels"
              class="w-full h-full object-cover"
              width="800"
              height="1000"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />

            <!-- Placeholder visible mientras no hay imagen -->
            <div class="absolute inset-0 bg-gradient-to-br from-charcoal-600 to-charcoal-700 flex flex-col items-center justify-center gap-4 border-2 border-dashed border-white/20">
              <svg class="w-16 h-16 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
              </svg>
              <div class="text-center px-6">
                <p class="text-white/40 text-sm font-semibold mb-1">Imagen Hero</p>
                <p class="text-white/25 text-xs font-light">Sube tu imagen a <code class="text-brand-400/60">public/images/hero.jpg</code></p>
                <p class="text-white/20 text-xs font-light mt-1">Recomendado: avión, aeropuerto o destino latinoamericano</p>
              </div>
            </div>

            <!-- Overlay gradiente para que el texto flote bien -->
            <div class="absolute inset-0 bg-gradient-to-t from-charcoal-700/60 via-transparent to-transparent pointer-events-none"></div>

            <!-- Badge flotante sobre la imagen -->
            <div class="absolute bottom-5 left-5 right-5">
              <div class="bg-white/15 backdrop-blur-md border border-white/20 rounded-2xl px-4 py-3 flex items-center gap-3">
                <div class="w-9 h-9 bg-brand-500 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-white text-sm font-semibold leading-tight">+500 viajeros satisfechos</p>
                  <p class="text-white/55 text-xs font-light">Valoración media 5 estrellas</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Tarjeta flotante lateral -->
          <div class="absolute -left-6 top-1/3 hidden xl:block bg-white rounded-2xl px-4 py-3.5 shadow-xl border border-gray-100">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 bg-brand-100 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-charcoal-700 text-xs font-bold leading-tight">20+ destinos</p>
                <p class="text-charcoal-400 text-xs font-light">en Latinoamérica</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 opacity-30">
    <span class="text-white text-xs font-medium tracking-widest uppercase">Scroll</span>
    <svg class="w-4 h-4 text-white animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
