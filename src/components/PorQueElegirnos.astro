---

<section id="por-que-elegirnos" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <div class="inline-flex items-center gap-2 bg-brand-100 rounded-full px-4 py-1.5 mb-5">
        <svg class="w-4 h-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span class="text-brand-600 text-sm font-semibold">Por qué elegirnos</span>
      </div>
      <h2 class="font-heading font-extrabold text-display-lg text-charcoal-700 mb-4">
        Tu viaje merece<br/>la mejor agencia
      </h2>
      <p class="text-charcoal-400 text-lg font-light leading-relaxed">
        Estas son las razones por las que cientos de latinoamericanos en España confían en Alevia Travels.
      </p>
    </div>

    <!-- Grid 4 cols en desktop -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {razones.map((r, i) => (
        <div class={`group p-6 rounded-2xl border transition-all duration-300 cursor-default hover:shadow-md hover:-translate-y-0.5 ${i === 0 ? 'bg-brand-500 border-brand-500 text-white' : 'bg-warm-50 border-gray-100 hover:border-brand-200'}`}>
          <div class={`w-11 h-11 rounded-xl flex items-center justify-center mb-4 ${i === 0 ? 'bg-white/20' : 'bg-brand-500'}`}>
            <svg
              class={`w-5 h-5 ${i === 0 ? 'text-white' : 'text-white'}`}
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              set:html={r.icon}
            ></svg>
          </div>
          <h3 class={`font-heading font-bold text-base mb-2 ${i === 0 ? 'text-white' : 'text-charcoal-700'}`}>{r.titulo}</h3>
          <p class={`text-sm font-light leading-relaxed ${i === 0 ? 'text-white/80' : 'text-charcoal-400'}`}>{r.descripcion}</p>
        </div>
      ))}
    </div>

    <!-- Bottom banner -->
    <div class="mt-14 bg-charcoal-700 rounded-2xl p-8 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-brand-500 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
        </div>
        <div>
          <p class="font-heading font-bold text-white text-lg">¿Listo para planificar tu viaje?</p>
          <p class="text-white/50 text-sm font-light">Consulta gratuita y sin compromiso. Te respondemos hoy.</p>
        </div>
      </div>
      <a
        href="#contacto"
        class="flex-shrink-0 inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-600 text-white font-semibold px-7 py-3.5 rounded-xl shadow-brand-lg transition-all duration-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-400 focus:ring-offset-2 focus:ring-offset-charcoal-700"
      >
        Empezar ahora
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
