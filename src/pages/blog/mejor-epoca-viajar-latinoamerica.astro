---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsApp from '../../components/WhatsApp.astro';

const whatsappUrl = 'https://wa.me/34600000000?text=Hola%2C%20me%20gustar%C3%ADa%20saber%20cu%C3%A1l%20es%20la%20mejor%20%C3%A9poca%20para%20viajar%20a%20Latinoam%C3%A9rica';

const destinos = [
  {
    pais: 'Colombia',
    mejorEpoca: 'Diciembre–marzo · Julio–agosto',
    clima: 'Clima cálido todo el año. Las temporadas secas son ideales para playas en Cartagena y senderismo en el Eje Cafetero.',
    evitar: 'Abril–mayo y octubre–noviembre (temporada de lluvias)',
  },
  {
    pais: 'México',
    mejorEpoca: 'Noviembre–abril',
    clima: 'La costa del Pacífico y el Caribe brillan con sol en invierno. Ciudad de México es agradable todo el año.',
    evitar: 'Junio–octubre en el Caribe (temporada de huracanes)',
  },
  {
    pais: 'Perú',
    mejorEpoca: 'Mayo–octubre',
    clima: 'Temporada seca en la sierra, perfecta para visitar Machu Picchu. Lima tiene clima templado todo el año.',
    evitar: 'Noviembre–abril en la sierra (lluvias intensas)',
  },
  {
    pais: 'Argentina',
    mejorEpoca: 'Octubre–abril',
    clima: 'El verano austral. Ideal para Buenos Aires, Mendoza y el norte. Patagonia es mejor en noviembre–marzo.',
    evitar: 'Julio–agosto en el sur (invierno patagónico muy duro)',
  },
  {
    pais: 'Rep. Dominicana',
    mejorEpoca: 'Diciembre–abril',
    clima: 'Temporada seca en el Caribe dominicano. Ideal para playas en Punta Cana y Samaná.',
    evitar: 'Agosto–octubre (pico de temporada de huracanes)',
  },
  {
    pais: 'Cuba',
    mejorEpoca: 'Noviembre–abril',
    clima: 'Clima seco y temperaturas perfectas para explorar La Habana, Trinidad y las playas de Varadero.',
    evitar: 'Junio–octubre (temporada de lluvias y ciclones)',
  },
];
---

<Layout
  title="La mejor época para viajar a Latinoamérica — Guía por destinos — Alevia Travels"
  description="Guía completa sobre cuándo viajar a Colombia, México, Perú, Argentina, Cuba y República Dominicana. Clima, temporadas y consejos prácticos para planificar tu viaje desde España."
>
  <Navbar />

  <main class="pt-20">
    <!-- Hero -->
    <div class="relative bg-warm-50 overflow-hidden py-16">
      <!-- Decoración -->
      <div class="pointer-events-none" aria-hidden="true">
        <div class="absolute -top-20 -right-20 w-72 h-72 rounded-full border-[24px] border-brand-500/8"></div>
        <div class="absolute -bottom-10 -left-10 w-48 h-48 rounded-full bg-brand-500/5"></div>
        <div class="absolute inset-0 opacity-[0.025]" style="background-image: radial-gradient(circle, #FF6E18 1.5px, transparent 1.5px); background-size: 32px 32px;"></div>
      </div>

      <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <a href="/blog" class="inline-flex items-center gap-1.5 text-brand-500 hover:text-brand-600 text-sm font-medium mb-8 transition-colors duration-200 cursor-pointer">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
          </svg>
          Volver al blog
        </a>

        <div class="inline-flex items-center gap-2 bg-brand-100 border border-brand-200 rounded-full px-3 py-1.5 mb-5">
          <svg class="w-3.5 h-3.5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>
          </svg>
          <span class="text-brand-600 text-xs font-semibold tracking-wide uppercase">Clima y temporadas</span>
        </div>

        <h1 class="font-heading font-extrabold text-3xl sm:text-4xl text-charcoal-700 leading-tight mb-4">
          La mejor época para viajar a Latinoamérica: guía destino a destino
        </h1>
        <p class="text-charcoal-400 text-base font-light leading-relaxed mb-6">
          El clima puede marcar la diferencia entre unas vacaciones perfectas y una decepción. Aquí te explicamos cuándo ir a cada destino.
        </p>
        <div class="flex items-center gap-4 text-charcoal-400 text-sm font-light">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
            </svg>
            Abril 2025
          </span>
          <span class="text-gray-300">·</span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            8 min de lectura
          </span>
        </div>
      </div>
    </div>

    <!-- Contenido -->
    <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-14">

      <p class="text-xl text-charcoal-600 font-normal leading-relaxed mb-10">
        Latinoamérica es un continente enorme con climas muy distintos según la región, la altitud y la época del año. Elegir bien el momento del viaje marca la diferencia entre disfrutar al máximo o encontrarte con lluvias torrenciales y vuelos llenos.
      </p>

      <!-- Tabla resumen visual -->
      <div class="space-y-5 mb-12">
        {destinos.map((d) => (
          <div class="bg-warm-50 border border-gray-100 rounded-2xl p-6 hover:border-brand-200 hover:shadow-sm transition-all duration-200">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h2 class="font-heading font-bold text-xl text-charcoal-700">{d.pais}</h2>
              <div class="flex-shrink-0 bg-brand-500 text-white text-xs font-semibold px-3 py-1.5 rounded-full">
                Mejor época
              </div>
            </div>
            <p class="text-brand-600 font-semibold text-sm mb-2">{d.mejorEpoca}</p>
            <p class="text-charcoal-400 text-sm font-light leading-relaxed mb-3">{d.clima}</p>
            <div class="flex items-start gap-2 bg-red-50 border border-red-100 rounded-xl px-3 py-2">
              <svg class="w-4 h-4 text-red-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
              </svg>
              <p class="text-red-600 text-xs font-light"><strong class="font-medium">Evitar:</strong> {d.evitar}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Tip final -->
      <div class="bg-charcoal-700 rounded-2xl p-8 text-center">
        <svg class="w-10 h-10 text-brand-400 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/>
        </svg>
        <h3 class="font-heading font-bold text-white text-xl mb-2">¿Tienes dudas sobre cuándo ir?</h3>
        <p class="text-white/55 text-sm font-light mb-6 max-w-sm mx-auto">
          En Alevia Travels te asesoramos sobre el mejor momento para cada destino según tu perfil de viajero.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-brand-500 hover:bg-brand-600 text-white font-semibold text-sm px-6 py-3 rounded-xl shadow-brand transition-all duration-200 cursor-pointer"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Preguntar por WhatsApp
          </a>
          <a
            href="tel:+34600000000"
            class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/18 border border-white/15 text-white font-semibold text-sm px-6 py-3 rounded-xl transition-all duration-200 cursor-pointer"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
            Llamar ahora
          </a>
        </div>
      </div>
    </article>
  </main>

  <Footer />
  <WhatsApp />
</Layout>
