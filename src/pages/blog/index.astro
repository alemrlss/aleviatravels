---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsApp from '../../components/WhatsApp.astro';

const articulos = [
  {
    slug: 'vuelos-baratos-latinoamerica-desde-espana',
    categoria: 'Vuelos y precios',
    titulo: 'Cómo encontrar vuelos baratos a Latinoamérica desde España',
    descripcion: 'Guía práctica con los mejores consejos para volar a Colombia, México, Perú, Argentina y más pagando el precio justo.',
    fecha: 'Abril 2025',
    lectura: '6 min',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>`,
  },
  {
    slug: 'mejor-epoca-viajar-latinoamerica',
    categoria: 'Clima y temporadas',
    titulo: 'La mejor época para viajar a Latinoamérica: guía destino a destino',
    descripcion: 'Colombia, México, Perú, Argentina, Cuba y República Dominicana — cuándo ir, cuándo evitar y qué esperar del clima.',
    fecha: 'Abril 2025',
    lectura: '8 min',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>`,
  },
];
---

<Layout
  title="Blog de viajes — Alevia Travels"
  description="Consejos, guías de destinos, ofertas de vuelos y todo lo que necesitas saber para viajar a Latinoamérica desde España."
>
  <Navbar />

  <main class="pt-20">
    <!-- Header -->
    <div class="bg-charcoal-700 py-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="inline-flex items-center gap-2 bg-brand-500/15 border border-brand-500/25 rounded-full px-4 py-1.5 mb-6">
          <svg class="w-4 h-4 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
          </svg>
          <span class="text-brand-300 text-sm font-semibold">Blog de viajes</span>
        </div>
        <h1 class="font-heading font-extrabold text-display-lg text-white mb-4">
          Consejos y guías<br/>para viajar mejor
        </h1>
        <p class="text-white/60 text-lg font-light max-w-xl">
          Información práctica para planificar tus viajes a Latinoamérica desde España. Sin relleno, solo lo útil.
        </p>
      </div>
    </div>

    <!-- Artículos -->
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {articulos.map((a) => (
          <a
            href={`/blog/${a.slug}`}
            class="group bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2"
          >
            <!-- Card header -->
            <div class="bg-charcoal-700 p-7 relative overflow-hidden">
              <div class="absolute top-0 right-0 w-40 h-40 bg-brand-500/10 rounded-full blur-2xl translate-x-1/3 -translate-y-1/3"></div>
              <div class="relative z-10">
                <div class="w-12 h-12 bg-brand-500/20 border border-brand-500/30 rounded-xl flex items-center justify-center mb-4">
                  <svg class="w-6 h-6 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={a.icon}></svg>
                </div>
                <span class="text-brand-400 text-xs font-semibold tracking-wide">{a.categoria}</span>
              </div>
            </div>

            <!-- Content -->
            <div class="p-6">
              <h2 class="font-heading font-bold text-lg text-charcoal-700 mb-2 group-hover:text-brand-500 transition-colors duration-200 leading-tight">{a.titulo}</h2>
              <p class="text-charcoal-400 text-sm font-light leading-relaxed mb-5">{a.descripcion}</p>

              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3 text-charcoal-400 text-xs font-light">
                  <span>{a.fecha}</span>
                  <span>·</span>
                  <span>{a.lectura} de lectura</span>
                </div>
                <div class="flex items-center gap-1 text-brand-500 text-sm font-semibold">
                  Leer
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                  </svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- CTA volver -->
      <div class="mt-12 text-center">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-charcoal-400 hover:text-brand-500 text-sm font-medium transition-colors duration-200 cursor-pointer"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
          </svg>
          Volver a la página principal
        </a>
      </div>
    </div>
  </main>

  <Footer />
  <WhatsApp />
</Layout>
